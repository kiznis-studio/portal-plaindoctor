---
import Base from '../../layouts/Base.astro';
import AdSlot from '../../components/ads/AdSlot.astro';
import { getProviderBySlug, formatProviderName, getStateName, getPrescriberSummary, formatNumber, getRelatedProviders, getSpecialtyStats } from '../../lib/db';

const { slug } = Astro.params;
const db = Astro.locals.runtime.env.DB;
const provider = await getProviderBySlug(db, slug!);

if (!provider) {
  Astro.response.status = 404;
  return Astro.redirect('/404');
}

const fullName = formatProviderName(provider);
const stateName = getStateName(provider.state);
const formattedPhone = provider.phone?.replace(/(\d{3})(\d{3})(\d{4})/, '($1) $2-$3');

// Get specialty slug for linking
const specRow = await db.prepare('SELECT slug FROM specialties WHERE code = ?').bind(provider.specialty_code).first<{ slug: string }>();
const specSlug = specRow?.slug || '';

// Get Part D prescriber data
const partD = await getPrescriberSummary(db, provider.npi);
const hasPrescribing = partD && partD.total_claims != null;
const brandPct = hasPrescribing && partD.brand_claims && partD.total_claims
  ? Math.round(100 * partD.brand_claims / partD.total_claims) : null;
const genericPct = brandPct != null ? 100 - brandPct : null;

// Related providers (same specialty, same state)
const relatedProviders = await getRelatedProviders(db, provider.specialty_code, provider.state, provider.npi, 6);

// Specialty context stats (for comparison)
const specStats = await getSpecialtyStats(db, provider.specialty_code);

// Schema.org Person markup
const personSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Physician',
  name: fullName,
  medicalSpecialty: provider.specialty,
  address: {
    '@type': 'PostalAddress',
    streetAddress: provider.address_line1,
    addressLocality: provider.city,
    addressRegion: provider.state,
    postalCode: provider.zip,
    addressCountry: 'US',
  },
  ...(provider.phone ? { telephone: formattedPhone } : {}),
  ...(provider.gender ? { gender: provider.gender === 'M' ? 'Male' : provider.gender === 'F' ? 'Female' : undefined } : {}),
});

const faqItems: { q: string; a: string }[] = [];
faqItems.push({
  q: `What is ${fullName}'s specialty?`,
  a: `${fullName} specializes in ${provider.specialty} and practices in ${provider.city}, ${stateName}.${provider.credential ? ` Credentials: ${provider.credential}.` : ''}`
});
if (hasPrescribing) {
  faqItems.push({
    q: `How much does ${fullName} prescribe under Medicare Part D?`,
    a: `In 2023, ${fullName} wrote ${formatNumber(partD.total_claims!)} Medicare Part D claims totaling $${partD.total_drug_cost! >= 1e6 ? (partD.total_drug_cost! / 1e6).toFixed(1) + 'M' : partD.total_drug_cost! >= 1e3 ? (partD.total_drug_cost! / 1e3).toFixed(0) + 'K' : Math.round(partD.total_drug_cost!).toLocaleString()} in drug costs for ${formatNumber(partD.total_beneficiaries!)} beneficiaries.`
  });
}
faqItems.push({
  q: `Where is ${fullName} located?`,
  a: `${fullName} is located at ${[provider.address_line1, provider.city, provider.state, provider.zip].filter(Boolean).join(', ')}.${formattedPhone ? ` Phone: ${formattedPhone}.` : ''}`
});
faqItems.push({
  q: `What is ${fullName}'s NPI number?`,
  a: `${fullName}'s National Provider Identifier (NPI) is ${provider.npi}${provider.enumeration_date ? `, issued on ${provider.enumeration_date}` : ''}.`
});
if (hasPrescribing && brandPct != null) {
  faqItems.push({
    q: `Does ${fullName} prescribe more brand-name or generic drugs?`,
    a: `${fullName}'s prescribing is ${brandPct}% brand-name and ${genericPct}% generic drugs by claim count${partD.brand_cost ? `, with $${partD.brand_cost >= 1e6 ? (partD.brand_cost / 1e6).toFixed(1) + 'M' : partD.brand_cost >= 1e3 ? (partD.brand_cost / 1e3).toFixed(0) + 'K' : Math.round(partD.brand_cost).toLocaleString()} in brand drug costs` : ''}.`
  });
}
if (hasPrescribing && partD.opioid_claims && partD.opioid_claims > 0) {
  faqItems.push({
    q: `Does ${fullName} prescribe opioids?`,
    a: `Yes, ${fullName} had ${formatNumber(partD.opioid_claims)} opioid claims in 2023${partD.opioid_prescriber_rate != null ? ` with an opioid prescribing rate of ${partD.opioid_prescriber_rate.toFixed(1)}%` : ''}.`
  });
}
if (specStats && specStats.total_providers) {
  faqItems.push({
    q: `How many ${provider.specialty} providers are there in the US?`,
    a: `There are ${formatNumber(specStats.total_providers)} ${provider.specialty} providers across ${specStats.states_count} states in the US.${specStats.avg_claims ? ` The average ${provider.specialty} provider writes ${formatNumber(specStats.avg_claims)} Medicare Part D claims per year.` : ''}`
  });
}

const faqSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
});
---

<Base
  title={`${provider.credential ? 'Dr. ' : ''}${provider.first_name} ${provider.last_name}${provider.credential ? ', ' + provider.credential : ''} — ${provider.specialty}${hasPrescribing ? `, ${formatNumber(partD.total_claims!)} Claims` : ''} | ${provider.city}, ${provider.state}`}
  description={`${fullName} is a ${provider.specialty} provider in ${provider.city}, ${stateName}.${hasPrescribing ? ` ${formatNumber(partD.total_claims!)} Medicare Part D claims in 2023.` : ''} NPI ${provider.npi}. View credentials, prescribing data & contact info.`}
  breadcrumbs={[
    { name: 'Home', href: '/' },
    { name: stateName, href: `/state/${stateName.toLowerCase().replace(/\s+/g, '-')}` },
    { name: fullName },
  ]}
>
  <section class="max-w-4xl mx-auto px-4 py-12">
    <div class="mb-8">
      <h1 class="text-3xl font-bold mb-2">{fullName}</h1>
      <p class="text-lg text-[var(--color-primary)]">{provider.specialty}</p>
      <p class="mt-3 text-[var(--color-text-secondary)] leading-relaxed max-w-3xl">
        <strong>{fullName}</strong> is a {provider.specialty} provider practicing in {provider.city}, {stateName}.{provider.credential ? ` Credentials: ${provider.credential}.` : ''} NPI: {provider.npi}.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-6 mb-8">
      <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl p-6">
        <h2 class="text-sm font-semibold text-[var(--color-text-secondary)] uppercase tracking-wide mb-4">Practice Address</h2>
        <div class="space-y-1">
          {provider.address_line1 && <div>{provider.address_line1}</div>}
          <div>{provider.city}, {provider.state} {provider.zip}</div>
          {formattedPhone && (
            <div class="mt-3">
              <a href={`tel:${provider.phone}`} class="text-[var(--color-primary)] hover:underline">{formattedPhone}</a>
            </div>
          )}
        </div>
      </div>

      <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl p-6">
        <h2 class="text-sm font-semibold text-[var(--color-text-secondary)] uppercase tracking-wide mb-4">Provider Details</h2>
        <dl class="space-y-2 text-sm">
          <div class="flex justify-between">
            <dt class="text-[var(--color-text-secondary)]">NPI</dt>
            <dd class="font-mono">{provider.npi}</dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-[var(--color-text-secondary)]">Specialty</dt>
            <dd>
              {specSlug ? (
                <a href={`/specialty/${specSlug}`} class="text-[var(--color-primary)] hover:underline">{provider.specialty}</a>
              ) : provider.specialty}
            </dd>
          </div>
          {provider.credential && (
            <div class="flex justify-between">
              <dt class="text-[var(--color-text-secondary)]">Credentials</dt>
              <dd>{provider.credential}</dd>
            </div>
          )}
          {provider.gender && (
            <div class="flex justify-between">
              <dt class="text-[var(--color-text-secondary)]">Gender</dt>
              <dd>{provider.gender === 'M' ? 'Male' : provider.gender === 'F' ? 'Female' : provider.gender}</dd>
            </div>
          )}
          {provider.enumeration_date && (
            <div class="flex justify-between">
              <dt class="text-[var(--color-text-secondary)]">NPI Issued</dt>
              <dd>{provider.enumeration_date}</dd>
            </div>
          )}
        </dl>
      </div>
    </div>

    {hasPrescribing && (
      <div class="mb-8">
        <h2 class="text-xl font-semibold mb-4">Medicare Part D Prescribing Data</h2>
        <p class="text-sm text-[var(--color-text-secondary)] mb-4">
          CMS Medicare Part D prescriber-level data for calendar year 2023.
        </p>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-4">
          <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl p-4">
            <div class="text-2xl font-bold">{formatNumber(partD.total_claims!)}</div>
            <div class="text-xs text-[var(--color-text-secondary)]">Total Claims</div>
          </div>
          <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl p-4">
            <div class="text-2xl font-bold">${partD.total_drug_cost! >= 1e6 ? (partD.total_drug_cost! / 1e6).toFixed(1) + 'M' : partD.total_drug_cost! >= 1e3 ? (partD.total_drug_cost! / 1e3).toFixed(0) + 'K' : formatNumber(Math.round(partD.total_drug_cost!))}</div>
            <div class="text-xs text-[var(--color-text-secondary)]">Total Drug Cost</div>
          </div>
          <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl p-4">
            <div class="text-2xl font-bold">{formatNumber(partD.total_beneficiaries!)}</div>
            <div class="text-xs text-[var(--color-text-secondary)]">Medicare Beneficiaries</div>
          </div>
        </div>

        <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl p-6">
          <h3 class="text-sm font-semibold text-[var(--color-text-secondary)] uppercase tracking-wide mb-3">Prescribing Breakdown</h3>
          <dl class="grid sm:grid-cols-2 gap-x-8 gap-y-2 text-sm">
            {partD.total_30day_fills != null && (
              <div class="flex justify-between">
                <dt class="text-[var(--color-text-secondary)]">30-Day Fills</dt>
                <dd class="font-medium">{formatNumber(partD.total_30day_fills)}</dd>
              </div>
            )}
            {partD.total_day_supply != null && (
              <div class="flex justify-between">
                <dt class="text-[var(--color-text-secondary)]">Total Day Supply</dt>
                <dd class="font-medium">{formatNumber(partD.total_day_supply)}</dd>
              </div>
            )}
            {brandPct != null && (
              <div class="flex justify-between">
                <dt class="text-[var(--color-text-secondary)]">Brand vs Generic</dt>
                <dd class="font-medium">{brandPct}% brand / {genericPct}% generic</dd>
              </div>
            )}
            {partD.brand_cost != null && (
              <div class="flex justify-between">
                <dt class="text-[var(--color-text-secondary)]">Brand Drug Cost</dt>
                <dd class="font-medium">${partD.brand_cost >= 1e6 ? (partD.brand_cost / 1e6).toFixed(1) + 'M' : partD.brand_cost >= 1e3 ? (partD.brand_cost / 1e3).toFixed(0) + 'K' : Math.round(partD.brand_cost).toLocaleString()}</dd>
              </div>
            )}
            {partD.generic_cost != null && (
              <div class="flex justify-between">
                <dt class="text-[var(--color-text-secondary)]">Generic Drug Cost</dt>
                <dd class="font-medium">${partD.generic_cost >= 1e6 ? (partD.generic_cost / 1e6).toFixed(1) + 'M' : partD.generic_cost >= 1e3 ? (partD.generic_cost / 1e3).toFixed(0) + 'K' : Math.round(partD.generic_cost).toLocaleString()}</dd>
              </div>
            )}
            {partD.opioid_claims != null && partD.opioid_claims > 0 && (
              <div class="flex justify-between">
                <dt class="text-[var(--color-text-secondary)]">Opioid Claims</dt>
                <dd class="font-medium">{formatNumber(partD.opioid_claims)}{partD.opioid_prescriber_rate != null ? ` (${partD.opioid_prescriber_rate.toFixed(1)}% rate)` : ''}</dd>
              </div>
            )}
            {partD.antibiotic_claims != null && partD.antibiotic_claims > 0 && (
              <div class="flex justify-between">
                <dt class="text-[var(--color-text-secondary)]">Antibiotic Claims</dt>
                <dd class="font-medium">{formatNumber(partD.antibiotic_claims)}</dd>
              </div>
            )}
          </dl>
        </div>

        {partD.bene_avg_age != null && (
          <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl p-6 mt-4">
            <h3 class="text-sm font-semibold text-[var(--color-text-secondary)] uppercase tracking-wide mb-3">Patient Demographics</h3>
            <dl class="grid sm:grid-cols-2 gap-x-8 gap-y-2 text-sm">
              <div class="flex justify-between">
                <dt class="text-[var(--color-text-secondary)]">Average Patient Age</dt>
                <dd class="font-medium">{partD.bene_avg_age.toFixed(1)} years</dd>
              </div>
              {partD.bene_avg_risk_score != null && (
                <div class="flex justify-between">
                  <dt class="text-[var(--color-text-secondary)]">Avg HCC Risk Score</dt>
                  <dd class="font-medium">{partD.bene_avg_risk_score.toFixed(2)}</dd>
                </div>
              )}
              {partD.bene_female != null && partD.bene_male != null && (
                <div class="flex justify-between">
                  <dt class="text-[var(--color-text-secondary)]">Gender Split</dt>
                  <dd class="font-medium">{Math.round(100 * partD.bene_female / (partD.bene_female + partD.bene_male))}% female / {Math.round(100 * partD.bene_male / (partD.bene_female + partD.bene_male))}% male</dd>
                </div>
              )}
              {partD.bene_age_lt65 != null && (
                <div class="flex justify-between">
                  <dt class="text-[var(--color-text-secondary)]">Age Distribution</dt>
                  <dd class="font-medium text-right">&lt;65: {formatNumber(partD.bene_age_lt65)}, 65-74: {formatNumber(partD.bene_age_65_74!)}, 75-84: {formatNumber(partD.bene_age_75_84!)}, 85+: {formatNumber(partD.bene_age_gt84!)}</dd>
                </div>
              )}
            </dl>
          </div>
        )}
      </div>
    )}

    <div class="flex flex-wrap gap-2 mb-8">
      {specSlug && (
        <a href={`/specialty/${specSlug}/${provider.state.toLowerCase()}`} class="text-sm px-4 py-2 bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg hover:border-[var(--color-primary)]">
          More {provider.specialty} in {provider.state} →
        </a>
      )}
      <a href={`/state/${stateName.toLowerCase().replace(/\s+/g, '-')}`} class="text-sm px-4 py-2 bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg hover:border-[var(--color-primary)]">
        All providers in {stateName} →
      </a>
    </div>

    {/* Specialty Context */}
    {specStats && specStats.total_providers > 0 && (
      <div class="mb-8">
        <h2 class="text-xl font-semibold mb-4">{provider.specialty} Overview</h2>
        <p class="text-sm text-[var(--color-text-secondary)] mb-4">
          How {fullName} fits within the {provider.specialty} landscape nationally.
        </p>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl p-4">
            <div class="text-2xl font-bold">{formatNumber(specStats.total_providers)}</div>
            <div class="text-xs text-[var(--color-text-secondary)]">{provider.specialty} Providers in US</div>
          </div>
          <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl p-4">
            <div class="text-2xl font-bold">{specStats.states_count}</div>
            <div class="text-xs text-[var(--color-text-secondary)]">States with {provider.specialty}</div>
          </div>
          {specStats.avg_claims && (
            <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl p-4">
              <div class="text-2xl font-bold">{formatNumber(specStats.avg_claims)}</div>
              <div class="text-xs text-[var(--color-text-secondary)]">Avg Claims per Provider</div>
            </div>
          )}
        </div>
        {hasPrescribing && specStats.avg_claims && (
          <p class="mt-3 text-sm text-[var(--color-text-secondary)]">
            {fullName}'s {formatNumber(partD.total_claims!)} claims are {partD.total_claims! > specStats.avg_claims ? 'above' : 'below'} the specialty average of {formatNumber(specStats.avg_claims)}.
          </p>
        )}
      </div>
    )}

    <AdSlot slot="mid" />

    {/* Related Providers */}
    {relatedProviders.length > 0 && (
      <div class="mb-8">
        <h2 class="text-xl font-semibold mb-4">Other {provider.specialty} Providers in {stateName}</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
          {relatedProviders.map(rp => (
            <a href={`/provider/${rp.slug}`} class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl p-4 hover:border-[var(--color-primary)] transition-colors">
              <div class="font-medium text-sm">{rp.credential ? 'Dr. ' : ''}{rp.first_name} {rp.last_name}</div>
              {rp.credential && <div class="text-xs text-[var(--color-text-secondary)]">{rp.credential}</div>}
              <div class="text-xs text-[var(--color-text-secondary)] mt-1">{rp.city}, {rp.state}</div>
            </a>
          ))}
        </div>
      </div>
    )}

    {/* Cross-Portal Health Data */}
    <div class="mb-8">
      <h2 class="text-xl font-semibold mb-4">Related Health Data</h2>
      <p class="text-sm text-[var(--color-text-secondary)] mb-4">
        Explore related healthcare data from our partner portals.
      </p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
        <a href={`https://plainhospital.com/state/${provider.state.toLowerCase()}`} class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl p-4 hover:border-[var(--color-primary)] transition-colors" target="_blank" rel="noopener">
          <div class="font-medium text-sm">Hospitals in {stateName}</div>
          <div class="text-xs text-[var(--color-text-secondary)] mt-1">Star ratings, quality measures & patient experience</div>
        </a>
        <a href={`https://plainnursing.com/state/${provider.state.toLowerCase()}`} class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl p-4 hover:border-[var(--color-primary)] transition-colors" target="_blank" rel="noopener">
          <div class="font-medium text-sm">Nursing Homes in {stateName}</div>
          <div class="text-xs text-[var(--color-text-secondary)] mt-1">Quality ratings, staffing & deficiency data</div>
        </a>
        <a href={`https://plainmeds.com`} class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl p-4 hover:border-[var(--color-primary)] transition-colors" target="_blank" rel="noopener">
          <div class="font-medium text-sm">Drug Information</div>
          <div class="text-xs text-[var(--color-text-secondary)] mt-1">FDA drug data, interactions & alternatives</div>
        </a>
      </div>
    </div>

    <div class="mb-8">
      <h2 class="text-lg font-semibold mb-4">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {faqItems.map(f => (
          <details class="group bg-[var(--color-surface)] rounded-lg border border-[var(--color-border)]">
            <summary class="flex items-center justify-between p-4 cursor-pointer font-medium text-[var(--color-text)]">
              {f.q}
              <span class="ml-2 text-[var(--color-text-secondary)] group-open:rotate-180 transition-transform">&#9660;</span>
            </summary>
            <div class="px-4 pb-4 text-[var(--color-text-secondary)] text-sm">{f.a}</div>
          </details>
        ))}
      </div>
    </div>

    {/* Data Sources & Methodology */}
    <div class="mb-8">
      <h2 class="text-lg font-semibold mb-4">Data Sources & Methodology</h2>
      <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl p-6">
        <dl class="space-y-3 text-sm">
          <div>
            <dt class="font-medium">Provider Directory</dt>
            <dd class="text-[var(--color-text-secondary)]">CMS National Plan and Provider Enumeration System (NPPES) — updated monthly. Contains NPI, specialty, credentials, and practice location.</dd>
          </div>
          {hasPrescribing && (
            <div>
              <dt class="font-medium">Prescribing Data</dt>
              <dd class="text-[var(--color-text-secondary)]">CMS Medicare Part D Prescriber Public Use File — Calendar Year 2023. Includes claims, drug costs, beneficiaries, and opioid prescribing rates.</dd>
            </div>
          )}
          <div>
            <dt class="font-medium">Methodology</dt>
            <dd class="text-[var(--color-text-secondary)]">Provider data is self-reported to CMS. Prescribing data reflects Medicare Part D only and does not include commercial insurance, Medicaid, or cash prescriptions. Claims below 11 beneficiaries are suppressed by CMS for privacy.</dd>
          </div>
        </dl>
      </div>
    </div>

    <div class="p-4 bg-amber-50 dark:bg-amber-950/30 border border-amber-200 dark:border-amber-800 rounded-lg text-sm mt-6">
      <p class="text-amber-800 dark:text-amber-200">
        <strong>Disclaimer:</strong> Data from CMS NPPES and Medicare Part D. PlainDoctor does not rate or rank providers. Provider information is self-reported and may not be current. Always verify information directly with the provider.
        <a href="/about" class="underline">Learn more</a>
      </p>
    </div>
  </section>
  <script type="application/ld+json" set:html={personSchema} />
  <script type="application/ld+json" set:html={faqSchema} />
</Base>
